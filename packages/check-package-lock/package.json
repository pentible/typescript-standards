{
    "name": "@pentible/check-package-lock",
    "version": "0.117.0",
    "description": "command to verify a package-lock.json is in sync with its package.json",
    "repository": {
        "type": "git",
        "url": "https://github.com/pentible/typescript-standards.git"
    },
    "license": "MIT",
    "author": "pentible",
    "type": "module",
    "exports": {
        ".": {
            "default": "./dist/main.js"
        }
    },
    "bin": {
        "check-package-lock": "./dist/main.js"
    },
    "files": [
        "dist/main.js"
    ],
    "scripts": {
        "build": "node esbuild.config.mjs",
        "dev": "npm run build -- --watch",
        "preinstall": "mkdir -p dist && touch dist/main.js",
        "lint:eslint": "eslint",
        "lint:prettier": "prettier --check --ignore-path ../../.gitignore .",
        "prepare": "npm run build",
        "typecheck": "tsc --noEmit"
    },
    "dependencies": {
        "@npmcli/arborist": "10.0.1"
    },
    "devDependencies": {
        "@types/node": "24.13.3",
        "@types/npmcli__arborist": "6.3.3",
        "@types/yargs": "17.0.35",
        "chalk": "5.4.1",
        "esbuild": "0.28.1",
        "execa": "8.0.1",
        "yargs": "18.0.0",
        "zod": "3.25.65"
    },
    "engines": {
        "node": ">=24"
    },
    "publishConfig": {
        "access": "public"
    }
}
